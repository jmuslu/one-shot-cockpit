BRIGHT_DATA_API_TOKEN=
BRIGHT_DATA_MCP_URL=https://mcp.brightdata.com/mcp

# Provider-agnostic agent loop. The built prompt is piped to this command's
# stdin, or substituted for {prompt} if the template contains it. The command
# runs in the shot's workspace, so the agent writes real files there.
# Examples:
#   ONESHOT_AGENT_CMD=claude -p --permission-mode bypassPermissions
#   ONESHOT_AGENT_CMD=codex exec {prompt}
ONESHOT_AGENT_CMD=
