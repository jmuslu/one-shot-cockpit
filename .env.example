BRIGHT_DATA_API_TOKEN=
BRIGHT_DATA_MCP_URL=https://mcp.brightdata.com/mcp
# Agent execution. Two ways to run a real build (otherwise a dispatch package
# is exported for manual runs):
#
# 1) Provider-agnostic shell agent. The spec prompt is piped to this command's
#    stdin, or substituted for {prompt} if the template contains it. Runs in the
#    shot's workspace, so the agent writes real files there. Examples:
#      ONESHOT_AGENT_CMD=claude -p --permission-mode acceptEdits
#      ONESHOT_AGENT_CMD=codex exec {prompt}
ONESHOT_AGENT_CMD=
#
# 2) Provider's own executor (currently codex exec). Set to true to allow it.
ONESHOT_RUNNER_EXECUTE=false
